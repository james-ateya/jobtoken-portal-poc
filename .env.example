MPESA_PASSKEY="bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919"
# Full public URL to this API route, e.g. https://your-app.vercel.app/api/mpesa/callback
MPESA_CALLBACK_URL=""
# Optional: CustomerPayBillOnline (default) or CustomerBuyGoodsOnline for Till-style flows
# MPESA_TRANSACTION_TYPE="CustomerPayBillOnline"

# JSON array of { "kes": number, "tokens": number } — optional; defaults are 100/5, 200/12, 500/35
# TOKEN_PACKS_JSON='[{"kes":100,"tokens":5},{"kes":200,"tokens":12}]'

# --- DEV: simulated wallet top-up (no real M-Pesa) ---
MPESA_SIMULATE="false"

# --- FRONTEND (Vite) ---
