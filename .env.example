# --- APP ---
APP_URL="http://localhost:3000"

# --- SUPABASE ---
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-public-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-secret-service-role-key"

# --- EMAIL (Resend is default when RESEND_API_KEY is set) ---
RESEND_API_KEY="re_your_api_key"
# Optional: verified sender for Resend (defaults to onboarding@resend.dev for testing)
# RESEND_FROM="JobToken <notifications@yourdomain.com>"

# To use SMTP instead: EMAIL_PROVIDER=smtp and fill SMTP_* below
# EMAIL_PROVIDER="smtp"
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="user@example.com"
SMTP_PASS="your-smtp-password"
SMTP_SECURE="false"
SMTP_FROM="JobToken <noreply@yourdomain.com>"
# EMAIL_FROM="JobToken <noreply@yourdomain.com>"

# --- M-PESA DARAJA (STK Push) ---
# Production base URL is https://api.safaricom.co.ke — or set MPESA_BASE_URL explicitly.
# MPESA_ENV="sandbox"
MPESA_CONSUMER_KEY="GD0Jej2cvGgH3KCjLo9UyTWJjA9BmaWkGl4baRrAOMwbargy"
MPESA_CONSUMER_SECRET="6MXSdwAd5gLcV2hzgQof9zGGVtLC0lneyC9Y1BJyV73sDeWfAeTAqAT99UzmACSY"
